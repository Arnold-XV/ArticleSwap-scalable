# ============================================================
# ArticleSwap - contoh konfigurasi lokal
# Salin file ini menjadi .env sebelum menjalankan Docker Compose:
#   copy .env.example .env        (Windows)
#   cp .env.example .env          (Linux/Mac)
# ============================================================

# App
# [OK] Tidak perlu diubah untuk development lokal.
APP_ENV=development
APP_NAME=ArticleSwap
PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# API Gateway
# [OK] Tidak perlu diubah. Port 8080 sudah dikonfigurasi di docker-compose.yml.
API_HOST=0.0.0.0
API_PORT=8080
API_READ_TIMEOUT_SECONDS=10
API_WRITE_TIMEOUT_SECONDS=10
# [OPSIONAL] Naikkan jika stress test sering kena rate limit (coba 300 atau 0 untuk disable).
API_RATE_LIMIT_PER_MINUTE=60

# PostgreSQL
# [OK] Hostname 'postgres' adalah nama service di docker-compose.yml. Jangan diubah.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=articleswap
# [OPSIONAL] Boleh diganti password yang lebih kuat untuk keamanan.
POSTGRES_USER=articleswap
POSTGRES_PASSWORD=articleswap
# [PERHATIAN] DATABASE_URL harus sinkron dengan POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_HOST, POSTGRES_DB di atas.
# Jika ubah salah satu, ubah di sini juga.
DATABASE_URL=postgres://articleswap:articleswap@postgres:5432/articleswap?sslmode=disable
# [OK] Pool size default sudah cukup untuk lokal. Naikkan MAX_CONNS jika stress test pakai banyak VU.
DB_POOL_MIN_CONNS=2
DB_POOL_MAX_CONNS=20
DB_POOL_MAX_CONN_LIFETIME_MINUTES=30

# Redis
# [OK] Hostname 'redis' adalah nama service di docker-compose.yml. Jangan diubah.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_ADDR=redis:6379
# [OK] Redis lokal tidak pakai password. Biarkan kosong.
REDIS_PASSWORD=
REDIS_DB=0
# [OK] TTL cache 24 jam (86400 detik). Aman dibiarkan default.
REDIS_CACHE_TTL_SECONDS=86400

# RabbitMQ
# [OK] Hostname 'rabbitmq' adalah nama service di docker-compose.yml. Jangan diubah.
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
# [OPSIONAL] Boleh diganti, tapi harus sinkron di RABBITMQ_URL di bawah.
RABBITMQ_DEFAULT_USER=articleswap
RABBITMQ_DEFAULT_PASS=articleswap
# [PERHATIAN] RABBITMQ_URL harus sinkron dengan RABBITMQ_DEFAULT_USER dan RABBITMQ_DEFAULT_PASS di atas.
RABBITMQ_URL=amqp://articleswap:articleswap@rabbitmq:5672/
# [OK] Nama exchange. Jangan diubah kecuali tahu apa yang dilakukan.
RABBITMQ_EXCHANGE=articles.exchange

# Queue names
# [OK] Jangan diubah. Nama queue sudah dikonfigurasi di broker/rabbitmq.go.
QUEUE_ARTICLE_SUBMITTED=articles.submitted
QUEUE_ARTICLE_STEMMING=articles.stemming
QUEUE_ARTICLE_WORDCLOUD=articles.wordcloud
QUEUE_ARTICLE_AGGREGATOR=articles.aggregator
QUEUE_ARTICLE_FAILED=articles.failed

# Worker behavior
# [OK] Dipake Aliya. Tidak berpengaruh ke API Gateway.
WORKER_CONCURRENCY=4
WORKER_MAX_RETRIES=3
WORKER_BACKOFF_BASE_MS=500
WORKER_BACKOFF_MAX_MS=8000
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_OPEN_SECONDS=30

# Frontend
# [OK] Menonaktifkan telemetri Next.js. Biarkan 1.
NEXT_TELEMETRY_DISABLED=1
